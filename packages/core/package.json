{
  "name": "@the-vault/core",
  "version": "0.6.4",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./provider-resolution": {
      "import": "./dist/config/provider-resolution.js",
      "types": "./dist/config/provider-resolution.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "provider-resolution": ["./dist/config/provider-resolution.d.ts"]
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/config/provider-resolution.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/config/provider-resolution.ts --format esm --dts --clean --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.0",
    "zod": "^3.24.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "drizzle-kit": "^0.31.10"
  }
}
