{
  "name": "@the-vault/desktop",
  "version": "0.6.3",
  "private": true,
  "description": "Desktop cockpit for The Vault local-first AI memory system",
  "author": "Ali Saad",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && pnpm run rebuild:native && electron-builder",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "verify:packaged-runtime": "node scripts/verify-packaged-runtime.mjs",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.alisaad.thevault",
    "productName": "The Vault",
    "icon": "public/vault-icon.png",
    "asar": true,
    "npmRebuild": false,
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "artifactName": "The-Vault-${version}-windows-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "The Vault"
    },
    "extraResources": [
      {
        "from": "../../mcp-standalone",
        "to": "mcp"
      },
      {
        "from": "../../skills",
        "to": "skills",
        "filter": [
          "*.md"
        ]
      }
    ]
  },
  "dependencies": {
    "@the-vault/core": "workspace:*",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.475.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.8.1",
    "electron-builder": "^26.15.3",
    "electron-builder-squirrel-windows": "^26.15.3",
    "node-gyp": "^12.4.0",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
