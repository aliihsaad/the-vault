{
  "name": "@the-vault/desktop",
  "version": "0.4.8",
  "private": true,
  "description": "Desktop cockpit for The Vault local-first AI memory system",
  "author": "Ali Saad",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.alisaad.thevault",
    "productName": "The Vault",
    "icon": "public/vault-icon.png",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-renderer/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "artifactName": "The-Vault-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "The Vault"
    },
    "extraResources": [
      {
        "from": "../../mcp-standalone",
        "to": "mcp",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../skills",
        "to": "skills",
        "filter": [
          "*.md"
        ]
      }
    ]
  },
  "dependencies": {
    "@the-vault/core": "workspace:*",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.475.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
