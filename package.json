{
  "name": "the-vault",
  "version": "0.6.4",
  "private": true,
  "description": "A local-first AI memory operating system for coding agents and humans",
  "author": "Ali Saad",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @the-vault/core build && pnpm --filter @the-vault/cli build && pnpm --filter @the-vault/mcp-server build && pnpm run deploy:mcp && pnpm --filter @the-vault/desktop build",
    "build:packages": "pnpm --filter @the-vault/core build && pnpm --filter @the-vault/cli build && pnpm --filter @the-vault/mcp-server build",
    "deploy:mcp": "node scripts/deploy-mcp.js",
    "setup:mcp": "node scripts/setup-mcp.js",
    "setup:mcp:dry-run": "node scripts/setup-mcp.js --dry-run",
    "dev": "pnpm -r --parallel dev",
    "dev:desktop": "pnpm -r --parallel --filter @the-vault/core --filter @the-vault/desktop run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm --filter @the-vault/core build && pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "tsup": "^8.4.0",
    "@types/node": "^22.12.0",
    "tsx": "^4.19.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core@7.29.0": "7.29.6",
      "@hono/node-server": "2.0.11",
      "@xmldom/xmldom": "0.8.13",
      "body-parser": "2.3.0",
      "esbuild@0.27.7": "0.28.1",
      "brace-expansion@1.1.14": "1.1.16",
      "brace-expansion@2.1.0": "2.1.2",
      "brace-expansion@5.0.5": "5.0.7",
      "express-rate-limit": "8.5.2",
      "fast-uri": "3.1.4",
      "form-data": "4.0.6",
      "hono": "4.12.31",
      "ip-address": "10.2.0",
      "js-yaml": "3.15.0",
      "postcss": "8.5.12",
      "qs": "6.15.3",
      "shell-quote": "1.9.0",
      "tmp": "0.2.7"
    }
  }
}
